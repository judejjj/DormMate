<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView android:id="@+id/tvVisitorName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Visitor Name" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />

        <TextView android:id="@+id/tvVisitorPhone"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="+91 XXXXXXXXXX" android:textColor="#AAAACC" android:textSize="12sp" />

        <TextView android:id="@+id/tvVisitingStudent"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Visiting: —" android:textColor="#B39DDB" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView android:id="@+id/tvVisitTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="14:00" android:textColor="#7B7B9D" android:textSize="11sp" />

        <TextView android:id="@+id/tvOverstayAlert"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🚨 Overstay Alert" android:textColor="#EF5350" android:textSize="10sp"
            android:textStyle="bold" android:visibility="gone" android:layout_marginTop="4dp" />
    </LinearLayout>
</LinearLayout>
