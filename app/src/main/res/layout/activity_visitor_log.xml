<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_aurora"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="24dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvVisitorBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="← Back"
                android:textColor="#B39DDB"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚪 Visitor Log"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Register Visitor Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Register New Visitor" android:textColor="#FFFFFF"
                android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="12dp" />

            <EditText android:id="@+id/etVisitorName"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Visitor Name" android:textColor="#FFFFFF" android:textColorHint="#7B7B9D"
                android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="10dp" />

            <EditText android:id="@+id/etVisitorPhone"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Phone Number" android:textColor="#FFFFFF" android:textColorHint="#7B7B9D"
                android:inputType="phone" android:paddingHorizontal="12dp" android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <EditText android:id="@+id/etVisitingStudent"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Visiting Student (Name/Room)" android:textColor="#FFFFFF" android:textColorHint="#7B7B9D"
                android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="10dp" />

            <EditText android:id="@+id/etVisitPurpose"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Purpose of Visit" android:textColor="#FFFFFF" android:textColorHint="#7B7B9D"
                android:paddingHorizontal="12dp" android:textSize="14sp" android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="10">

                <Button android:id="@+id/btnCaptureFace"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="3" android:layout_marginEnd="8dp"
                    android:backgroundTint="#22223B"
                    android:text="📷 FACE"
                    android:textColor="#FFFFFF" />

                <Button android:id="@+id/btnRegisterVisitor"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="7"
                    android:background="@drawable/bg_button_violet"
                    android:text="REGISTER VISITOR"
                    android:textColor="#FFFFFF" android:textStyle="bold"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

        <!-- Past Visitors List -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Recent Visitors" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvVisitors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>
